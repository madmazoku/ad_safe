#!/usr/bin/env python3

from datetime import datetime
from pathlib import Path
from tempfile import NamedTemporaryFile

import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import torch
import torch.nn as nn
import torch.optim as optim
from PIL import Image
from torch.utils.data import DataLoader, TensorDataset
from torchvision import datasets, models, transforms

import random
import time
import argparse

SCRIPT_DIR = Path(__file__).resolve().parent
DATA_DIR = SCRIPT_DIR / "ml_bootcamp_adsafety_dataset"
BATCH_SIZE = 32
EPOCHS = 10
LR = 1e-4
DEVICE = "cuda" if torch.cuda.is_available() else "cpu"
IMAGE_TRANSFORM = transforms.Compose(
    [
        transforms.Resize((299, 299)),
        transforms.ToTensor(),
    ]
)


def get_logits(outputs):
    return outputs.logits if hasattr(outputs, "logits") else outputs


def validate_model(model, val_loader, criterion):
    print("Validating model...")
    model.eval()
    val_loss = 0.0
    correct = 0
    with torch.no_grad():
        for images, labels in val_loader:
            images, labels = images.to(DEVICE), labels.to(DEVICE)
            outputs = get_logits(model(images))
            loss = criterion(outputs, labels)
            val_loss += loss.item()
            
            # Calculate accuracy
            preds = outputs.argmax(dim=1)
            correct += (preds == labels).sum().item()
    
    avg_loss = val_loss / len(val_loader)
    accuracy = correct / len(val_loader.dataset)
    return avg_loss, accuracy


def train_model_epoch(model, train_loader, optimizer, criterion):
    model.train()
    running_loss = 0.0
    for images, labels in train_loader:
        images, labels = images.to(DEVICE), labels.to(DEVICE)

        optimizer.zero_grad()
        outputs = get_logits(model(images))
        loss = criterion(outputs, labels)
        loss.backward()
        optimizer.step()

        running_loss += loss.item()
    avg_loss = running_loss / len(train_loader)
    return avg_loss

def generate_adversarial_loader(model, train_loader, criterion, epsilon, num_steps_adv):
    print(f"Generating adversarial examples from train dataset (epsilon={epsilon}, steps={num_steps_adv})...")
    adversarial_images = []
    adversarial_labels = []
    for images, labels in train_loader:
        images, labels = images.to(DEVICE), labels.to(DEVICE)
        adv_images, _ = generate_adversarial_batch(model, images, labels, criterion, epsilon, num_steps_adv)
        adversarial_images.append(adv_images.cpu())
        adversarial_labels.append(labels.cpu())
    adversarial_images = torch.cat(adversarial_images)
    adversarial_labels = torch.cat(adversarial_labels)
    
    adv_dataset = TensorDataset(adversarial_images, adversarial_labels)
    adv_loader = DataLoader(adv_dataset, batch_size=train_loader.batch_size, shuffle=True)
    return adv_loader

def train_model(model, train_loader, val_loader, optimizer, criterion, epochs, patience=5, adversarial=False, epsilon=0.15, num_steps_adv=20):
    """
    Train with early stopping to prevent overfitting.
    Supports adversarial training by first training on clean data, then generating adversarial examples from train dataset, then training on adversarial data.

    Args:
        patience: Stop if validation accuracy doesn't improve for this many epochs
        adversarial: If True, enable adversarial training
        epsilon: Adversarial perturbation magnitude
        num_steps_adv: FGSM steps for adversarial generation
    """
    
    print("Starting training.")

    with NamedTemporaryFile(suffix=".pth", delete=False) as tmp_file:
        start_time = time.time()
        
        best_val_accuracy = 0.0
        best_epoch = 0
        patience_counter = 0
        
        for epoch in range(epochs):
            avg_train_loss = train_model_epoch(model, train_loader, optimizer, criterion)
            avg_adv_train_loss = 0.0
            if adversarial:
                adv_loader = generate_adversarial_loader(model, train_loader, criterion, epsilon, num_steps_adv)
                avg_adv_train_loss = train_model_epoch(model, adv_loader, optimizer, criterion)

            avg_val_loss, val_accuracy = validate_model(model, val_loader, criterion)
            training_time = time.time() - start_time
            
            # Early stopping logic
            if val_accuracy > best_val_accuracy:
                best_val_accuracy = val_accuracy
                best_epoch = epoch + 1
                patience_counter = 0
                # Save best model
                save_model(model, tmp_file.name)
            else:
                patience_counter += 1
            
            print(
                f"Epoch {epoch+1}/{epochs}, "
                f"Train Loss: {avg_train_loss:.4f}, "
                f"Adv Train Loss: {avg_adv_train_loss:.4f}, "
                f"Val Loss: {avg_val_loss:.4f}, "
                f"Val Accuracy: {val_accuracy:.4f} "
                f"(Best: {best_val_accuracy:.4f} at epoch {best_epoch}). "
                f"Training time: {training_time:.2f}s"
            )
            
            # Early stopping
            if patience_counter >= patience:
                print(f"\nEarly stopping at epoch {epoch+1} (patience={patience})")
                break
        
        # Load best model
        reload_model(model, tmp_file.name)
        print(f"Loaded best model from epoch {best_epoch} (val accuracy: {best_val_accuracy:.4f})")


def save_model(model, filename):
    print(f"Saving model to {filename}...")
    torch.save(model.state_dict(), filename)
    print(f"Model saved to {filename}")


def make_model(weights="IMAGENET1K_V1"):
    print("Creating model...")
    model = models.inception_v3(weights=weights)
    model.fc = nn.Linear(model.fc.in_features, 2)
    model = model.to(DEVICE)
    return model


def load_model(filename):
    print(f"Loading model from {filename}...")
    loaded_model = make_model(weights=None)
    reload_model(loaded_model, filename)
    loaded_model.eval()
    return loaded_model

def reload_model(model, filename):
    model.load_state_dict(torch.load(filename, map_location=DEVICE))


def generate_adversarial_perturbation(model, x_original, criterion, epsilon=0.15, num_steps=40):
    """
    Generate adversarial perturbation using untargeted iterative FGSM.
    
    Args:
        model: Neural network model
        x_original: Original input tensor (batch)
        criterion: Loss function
        epsilon: Max perturbation magnitude
        num_steps: Number of FGSM iterations
    
    Returns:
        x_adv: Adversarial tensor with perturbations
    """
    x_adv = x_original.detach().clone()
    step_size = epsilon / num_steps
    
    # Get original predictions for loss computation
    with torch.no_grad():
        original_logits = get_logits(model(x_original))
        original_pred = original_logits.argmax(dim=1)
    
    for step in range(num_steps):
        x_adv.requires_grad_(True)
        
        # Forward pass
        logits = get_logits(model(x_adv))
        
        # Untargeted: minimize loss w.r.t. original prediction
        loss = criterion(logits, original_pred)
        
        # Backward pass
        loss.backward()
        
        # Update with gradient sign
        with torch.no_grad():
            grad = x_adv.grad.sign()
            x_adv = x_adv + step_size * grad
            # Clip to epsilon ball
            x_adv = torch.clamp(x_adv, x_original - epsilon, x_original + epsilon)
            # Clip to valid image range
            x_adv = torch.clamp(x_adv, 0, 1)
        
        x_adv = x_adv.detach()
    
    return x_adv


def evaluate_adversarial(model, x_original, x_adv):
    """
    Evaluate original and adversarial predictions.
    
    Returns:
        (original_preds, original_confs, adv_preds, adv_confs)
    """
    model.eval()
    with torch.no_grad():
        orig_logits = get_logits(model(x_original))
        adv_logits = get_logits(model(x_adv))
        
        orig_probs = torch.softmax(orig_logits, dim=1)
        adv_probs = torch.softmax(adv_logits, dim=1)
        
        orig_preds = orig_logits.argmax(dim=1)
        adv_preds = adv_logits.argmax(dim=1)
        
        orig_confs = orig_probs.gather(1, orig_preds.unsqueeze(1)).squeeze(1)
        adv_confs = adv_probs.gather(1, adv_preds.unsqueeze(1)).squeeze(1)
    
    return orig_preds, orig_confs, adv_preds, adv_confs


def generate_adversarial_batch(model, images_batch, labels_batch, criterion, epsilon=0.15, num_steps=20):
    """
    Generate adversarial batch for training (keeps true labels).
    
    Args:
        model: Neural network model
        images_batch: Batch of images
        labels_batch: True labels (unchanged)
        criterion: Loss function
        epsilon: Perturbation magnitude
        num_steps: FGSM iterations
    
    Returns:
        (adversarial_images, labels_batch) - Keep true labels for training
    """
    adv_images = generate_adversarial_perturbation(model, images_batch, criterion, epsilon, num_steps)
    return adv_images, labels_batch


def generate_adversarial_example(model, image_path, run_timestamp, epsilon=0.15, num_steps=40):
    """
    Demo: Generate and visualize adversarial example from single image.
    
    Args:
        model: Trained PyTorch model
        image_path: Path to the input image
        run_timestamp: Timestamp string for filename
        epsilon: Perturbation magnitude (0-1 scale)
        num_steps: Number of FGSM steps
    """
    class_names = ["safe", "unsafe"]
    criterion = nn.CrossEntropyLoss()
    
    # Print relative path of image being used
    image_path = Path(image_path)
    try:
        rel_path = image_path.relative_to(SCRIPT_DIR)
    except ValueError:
        rel_path = image_path
    print(f"Using image: {rel_path}")
    
    # Load and preprocess image
    img = Image.open(image_path).convert("RGB")
    input_tensor = IMAGE_TRANSFORM(img).unsqueeze(0).to(DEVICE).float()
    original_tensor = input_tensor.detach().clone()
    
    # Get true label from path
    true_label = image_path.parent.name
    
    # Generate adversarial perturbation
    adversarial_tensor = generate_adversarial_perturbation(model, original_tensor, criterion, epsilon, num_steps)
    
    # Evaluate
    orig_preds, orig_confs, adv_preds, adv_confs = evaluate_adversarial(model, original_tensor, adversarial_tensor)
    
    # Convert to numpy for visualization
    original_img_np = original_tensor[0].detach().cpu().permute(1, 2, 0).numpy()
    adversarial_img_np = adversarial_tensor[0].detach().cpu().permute(1, 2, 0).numpy()
    
    # Visualize
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    
    axes[0].imshow(original_img_np)
    axes[0].set_title(f"Original: {true_label}\nPred: {class_names[orig_preds[0]]} ({orig_confs[0]:.3f})")
    axes[0].axis("off")
    
    axes[1].imshow(adversarial_img_np)
    axes[1].set_title(f"Adversarial\nPred: {class_names[adv_preds[0]]} ({adv_confs[0]:.3f})")
    axes[1].axis("off")
    
    plt.tight_layout()
    
    # Save figure
    output_filename = SCRIPT_DIR / f"{run_timestamp}_{true_label}_adversarial.png"
    plt.savefig(output_filename, dpi=100, bbox_inches="tight")
    plt.close()
    
    print(f"Adversarial example saved to {output_filename}")
    print(f"  True label: {true_label}")
    print(f"  Original prediction: {class_names[orig_preds[0]]} (confidence: {orig_confs[0]:.3f})")
    print(f"  Adversarial prediction: {class_names[adv_preds[0]]} (confidence: {adv_confs[0]:.3f})")
    print(f"  Attack successful: {orig_preds[0] != adv_preds[0]}")
    
    return output_filename





def test_model(model, pathname, run_timestamp):
    print(f"Testing model using images from {pathname}...")
    model.eval()
    images = list(Path(pathname).glob("*/*"))
    if not images:
        raise ValueError(f"No test images found under {pathname}/*/*")

    img_path = random.choice(images)
    img = Image.open(img_path).convert("RGB")
    input_tensor = IMAGE_TRANSFORM(img).unsqueeze(0).to(DEVICE)

    with torch.no_grad():
        output = get_logits(model(input_tensor))
        probs = torch.softmax(output, dim=1)
        pred = probs.argmax(dim=1).item()
        confidence = probs[0, pred].item()

    class_names = ["safe", "unsafe"]
    true_label = img_path.parent.name
    output_path = SCRIPT_DIR / f"{run_timestamp}-output.png"

    plt.imshow(img)
    plt.title(f"True: {true_label}, Pred: {class_names[pred]} ({confidence:.3f})")
    plt.axis("off")
    plt.savefig(output_path)
    print(f"Plot saved to {output_path}")


def main():
    # Parse command-line arguments
    parser = argparse.ArgumentParser(description="Train model for ad safety classification with optional adversarial training")
    parser.add_argument("--model-path", type=str, default=None, help="Load pre-trained model without training")
    parser.add_argument("--adversarial", action="store_true", help="Enable adversarial training")
    parser.add_argument("--adv-epsilon", type=float, default=0.15, help="Adversarial perturbation magnitude")
    parser.add_argument("--adv-steps", type=int, default=20, help="FGSM iterations for adversarial batch generation")
    parser.add_argument("--epochs", type=int, default=EPOCHS, help="Number of training epochs")
    parser.add_argument("--batch-size", type=int, default=BATCH_SIZE, help="Training batch size")
    args = parser.parse_args()
    
    run_timestamp = datetime.now().strftime("%Y-%m-%d-%H-%M-%S")

    # Verify model path
    model_path = None
    if args.model_path is not None:
        model_path = Path(args.model_path)
        if not model_path.exists():
            raise FileNotFoundError(f"Specified model path does not exist: {model_path}")


    print(f"Using device: {DEVICE}")
    print(f"Loading datasets from {DATA_DIR}...")
    train_dataset = datasets.ImageFolder(DATA_DIR / "train", transform=IMAGE_TRANSFORM)
    val_dataset = datasets.ImageFolder(DATA_DIR / "val", transform=IMAGE_TRANSFORM)
    test_dataset = datasets.ImageFolder(DATA_DIR / "test", transform=IMAGE_TRANSFORM)

    train_loader = DataLoader(train_dataset, batch_size=args.batch_size, shuffle=True)
    val_loader = DataLoader(val_dataset, batch_size=args.batch_size)

    # Determine model source (trained or new)
    if model_path is not None:
        model = load_model(model_path)
        print("Skipping training. Running test and adversarial demo.")
    else:
        model = make_model()

    criterion = nn.CrossEntropyLoss()
    optimizer = optim.Adam(model.parameters(), lr=LR)

    # Choose execution strategy: train only if no pre-trained model path is provided
    if model_path is None:
        model_path = SCRIPT_DIR / f"{run_timestamp}-model.pth"
        train_model(model, train_loader, val_loader, optimizer, criterion, args.epochs, adversarial=args.adversarial, epsilon=args.adv_epsilon, num_steps_adv=args.adv_steps, batch_size=args.batch_size)
    else:
        print(f"Loaded model from: {model_path}")
        print("Skipping training. Running test and adversarial demo.")
    
    # Test and adversarial example use final loaded model (trained or loaded)
    test_model(model, DATA_DIR / "test", run_timestamp)

    # Generate adversarial example
    print("\nGenerating adversarial attack example...")
    test_images = list((DATA_DIR / "test").glob("*/*"))
    if test_images:
        random_test_image = random.choice(test_images)
        generate_adversarial_example(model, random_test_image, run_timestamp)


if __name__ == "__main__":
    main()
