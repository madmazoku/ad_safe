#!/usr/bin/env python3

import argparse
import random
import time
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from tempfile import NamedTemporaryFile

import matplotlib

matplotlib.use("Agg")
import matplotlib.pyplot as plt
import torch
from PIL import Image
from torch import Tensor, nn, optim
from torch.utils.data import DataLoader, TensorDataset
from tqdm.auto import tqdm
from torchvision import datasets, models, transforms

SCRIPT_DIR = Path(__file__).resolve().parent
DATA_DIR = SCRIPT_DIR / "ml_bootcamp_adsafety_dataset"
CLASS_NAMES = ["safe", "unsafe"]
IMAGE_SIZE = 299
DEFAULT_BATCH_SIZE = 32
DEFAULT_EPOCHS = 3
DEFAULT_LR = 1e-4
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")


@dataclass(frozen=True)
class TrainingConfig:
    epochs: int = DEFAULT_EPOCHS
    patience: int = 5
    batch_size: int = DEFAULT_BATCH_SIZE
    learning_rate: float = DEFAULT_LR
    adversarial: bool = False
    adv_epsilon: float = 0.15
    adv_steps: int = 20


IMAGE_TRANSFORM = transforms.Compose(
    [
        transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),
        transforms.ToTensor(),
    ]
)


def make_seed() -> int:
    return random.SystemRandom().randrange(2**32)


def set_seed(seed: int) -> None:
    random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False


def get_logits(outputs: Tensor | object) -> Tensor:
    return outputs.logits if hasattr(outputs, "logits") else outputs


def to_device(*tensors: Tensor, device: torch.device = DEVICE) -> tuple[Tensor, ...]:
    return tuple(tensor.to(device) for tensor in tensors)


def make_data_loader(dataset, *, batch_size: int, shuffle: bool) -> DataLoader:
    return DataLoader(
        dataset,
        batch_size=batch_size,
        shuffle=shuffle,
        pin_memory=torch.cuda.is_available(),
    )


def validate_model(model: nn.Module, val_loader: DataLoader, criterion: nn.Module) -> tuple[float, float]:
    model.eval()
    total_loss = 0.0
    total_correct = 0

    with torch.inference_mode():
        for images, labels in tqdm(
            val_loader,
            desc="Validation",
            leave=False,
        ):
            images, labels = to_device(images, labels)
            logits = get_logits(model(images))
            total_loss += criterion(logits, labels).item()
            total_correct += (logits.argmax(dim=1) == labels).sum().item()

    return total_loss / len(val_loader), total_correct / len(val_loader.dataset)


def train_model_epoch(
    model: nn.Module,
    train_loader: DataLoader,
    optimizer: optim.Optimizer,
    criterion: nn.Module,
    epoch_type: str,
) -> float:
    model.train()
    total_loss = 0.0

    for images, labels in tqdm(
        train_loader,
        desc=f"Training ({epoch_type})",
        leave=False,
    ):
        images, labels = to_device(images, labels)
        optimizer.zero_grad(set_to_none=True)
        logits = get_logits(model(images))
        loss = criterion(logits, labels)
        loss.backward()
        optimizer.step()
        total_loss += loss.item()

    return total_loss / len(train_loader)


def generate_adversarial_loader(
    model: nn.Module,
    train_loader: DataLoader,
    criterion: nn.Module,
    epsilon: float,
    num_steps: int,
) -> DataLoader:
    print(
        f"Generating adversarial examples from train dataset "
        f"(epsilon={epsilon}, steps={num_steps})..."
    )
    adversarial_images: list[Tensor] = []
    adversarial_labels: list[Tensor] = []

    for images, labels in tqdm(
        train_loader,
        desc="Adversarial batches",
        leave=False,
    ):
        images, labels = to_device(images, labels)
        adv_images, adv_labels = generate_adversarial_batch(
            model=model,
            images_batch=images,
            labels_batch=labels,
            criterion=criterion,
            epsilon=epsilon,
            num_steps=num_steps,
        )
        adversarial_images.append(adv_images.cpu())
        adversarial_labels.append(adv_labels.cpu())

    adv_dataset = TensorDataset(
        torch.cat(adversarial_images, dim=0),
        torch.cat(adversarial_labels, dim=0),
    )
    return make_data_loader(
        adv_dataset,
        batch_size=train_loader.batch_size or DEFAULT_BATCH_SIZE,
        shuffle=True,
    )


def train_model(
    model: nn.Module,
    train_loader: DataLoader,
    val_loader: DataLoader,
    optimizer: optim.Optimizer,
    criterion: nn.Module,
    config: TrainingConfig,
) -> None:
    print("Starting training.")
    best_val_accuracy = float("-inf")
    best_epoch = 0
    patience_counter = 0
    start_time = time.time()

    with NamedTemporaryFile(suffix=".pth", delete=False) as tmp_file:
        best_model_path = Path(tmp_file.name)

    try:
        for epoch in range(1, config.epochs + 1):
            avg_train_loss = train_model_epoch(model, train_loader, optimizer, criterion, "train")
            avg_adv_train_loss = 0.0

            if config.adversarial:
                adv_loader = generate_adversarial_loader(
                    model=model,
                    train_loader=train_loader,
                    criterion=criterion,
                    epsilon=config.adv_epsilon,
                    num_steps=config.adv_steps,
                )
                avg_adv_train_loss = train_model_epoch(model, adv_loader, optimizer, criterion, "adversarial")

            avg_val_loss, val_accuracy = validate_model(model, val_loader, criterion)
            elapsed = time.time() - start_time

            print(
                f"Epoch {epoch}/{config.epochs} | "
                f"train={avg_train_loss:.4f} | "
                f"adv_train={avg_adv_train_loss:.4f} | "
                f"val={avg_val_loss:.4f} | "
                f"val_acc={val_accuracy:.4f} | "
                f"best={best_val_accuracy:.4f} @ epoch {best_epoch} | "
                f"time={elapsed:.2f}s"
            )

            if val_accuracy >= best_val_accuracy:
                best_val_accuracy = val_accuracy
                best_epoch = epoch
                patience_counter = 0
                save_model(model, best_model_path)
            else:
                patience_counter += 1

            if patience_counter >= config.patience:
                print(f"Early stopping at epoch {epoch} (patience={config.patience})")
                break

        reload_model(model, best_model_path)
        print(f"Loaded best model from epoch {best_epoch} (val accuracy: {best_val_accuracy:.4f})")
    finally:
        best_model_path.unlink(missing_ok=True)


def save_model(model: nn.Module, filename: str | Path) -> None:
    filename = Path(filename)
    print(f"Saving model to {filename}...")
    torch.save(model.state_dict(), filename)


def make_model(weights: str | None = "IMAGENET1K_V1") -> nn.Module:
    print("Creating model...")
    model = models.inception_v3(weights=weights)
    model.fc = nn.Linear(model.fc.in_features, len(CLASS_NAMES))
    return model.to(DEVICE)


def reload_model(model: nn.Module, filename: str | Path) -> None:
    state_dict = torch.load(filename, map_location=DEVICE)
    model.load_state_dict(state_dict)


def load_model(filename: str | Path) -> nn.Module:
    print(f"Loading model from {filename}...")
    loaded_model = make_model(weights=None)
    reload_model(loaded_model, filename)
    loaded_model.eval()
    return loaded_model


def generate_adversarial_perturbation(
    model: nn.Module,
    x_original: Tensor,
    criterion: nn.Module,
    epsilon: float = 0.15,
    num_steps: int = 40,
) -> Tensor:
    if num_steps <= 0:
        raise ValueError("num_steps must be positive")

    x_adv = x_original.detach().clone()
    step_size = epsilon / num_steps

    with torch.no_grad():
        original_pred = get_logits(model(x_original)).argmax(dim=1)

    was_training = model.training
    model.eval()

    for _ in range(num_steps):
        x_adv.requires_grad_(True)
        model.zero_grad(set_to_none=True)
        logits = get_logits(model(x_adv))
        loss = criterion(logits, original_pred)
        grad = torch.autograd.grad(loss, x_adv)[0]

        with torch.no_grad():
            x_adv = x_adv + step_size * grad.sign()
            x_adv = torch.clamp(x_adv, x_original - epsilon, x_original + epsilon)
            x_adv = torch.clamp(x_adv, 0.0, 1.0)
            x_adv = x_adv.detach()

    model.train(was_training)
    return x_adv


def evaluate_adversarial(model: nn.Module, x_original: Tensor, x_adv: Tensor) -> tuple[Tensor, Tensor, Tensor, Tensor]:
    model.eval()
    with torch.inference_mode():
        orig_logits = get_logits(model(x_original))
        adv_logits = get_logits(model(x_adv))

        orig_probs = torch.softmax(orig_logits, dim=1)
        adv_probs = torch.softmax(adv_logits, dim=1)

        orig_preds = orig_logits.argmax(dim=1)
        adv_preds = adv_logits.argmax(dim=1)

        orig_confs = orig_probs.gather(1, orig_preds.unsqueeze(1)).squeeze(1)
        adv_confs = adv_probs.gather(1, adv_preds.unsqueeze(1)).squeeze(1)

    return orig_preds, orig_confs, adv_preds, adv_confs


def generate_adversarial_batch(
    model: nn.Module,
    images_batch: Tensor,
    labels_batch: Tensor,
    criterion: nn.Module,
    epsilon: float = 0.15,
    num_steps: int = 20,
) -> tuple[Tensor, Tensor]:
    adv_images = generate_adversarial_perturbation(
        model=model,
        x_original=images_batch,
        criterion=criterion,
        epsilon=epsilon,
        num_steps=num_steps,
    )
    return adv_images, labels_batch


def load_image_tensor(image_path: str | Path) -> tuple[Image.Image, Tensor]:
    image = Image.open(image_path).convert("RGB")
    tensor = IMAGE_TRANSFORM(image).unsqueeze(0).to(DEVICE)
    return image, tensor


def generate_adversarial_example(
    model: nn.Module,
    image_path: str | Path,
    run_timestamp: str,
    epsilon: float = 0.15,
    num_steps: int = 40,
) -> Path:
    criterion = nn.CrossEntropyLoss()
    image_path = Path(image_path)

    try:
        rel_path = image_path.relative_to(SCRIPT_DIR)
    except ValueError:
        rel_path = image_path
    print(f"Using image: {rel_path}")

    _, original_tensor = load_image_tensor(image_path)
    true_label = image_path.parent.name
    adversarial_tensor = generate_adversarial_perturbation(
        model=model,
        x_original=original_tensor,
        criterion=criterion,
        epsilon=epsilon,
        num_steps=num_steps,
    )
    orig_preds, orig_confs, adv_preds, adv_confs = evaluate_adversarial(
        model, original_tensor, adversarial_tensor
    )

    original_img_np = original_tensor[0].detach().cpu().permute(1, 2, 0).numpy()
    adversarial_img_np = adversarial_tensor[0].detach().cpu().permute(1, 2, 0).numpy()

    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    axes[0].imshow(original_img_np)
    axes[0].set_title(
        f"Original: {true_label}\nPred: {CLASS_NAMES[orig_preds[0]]} ({orig_confs[0]:.3f})"
    )
    axes[0].axis("off")

    axes[1].imshow(adversarial_img_np)
    axes[1].set_title(
        f"Adversarial\nPred: {CLASS_NAMES[adv_preds[0]]} ({adv_confs[0]:.3f})"
    )
    axes[1].axis("off")

    plt.tight_layout()
    output_filename = SCRIPT_DIR / f"{run_timestamp}_{true_label}_adversarial.png"
    plt.savefig(output_filename, dpi=100, bbox_inches="tight")
    plt.close(fig)

    print(f"Adversarial example saved to {output_filename}")
    print(f"  True label: {true_label}")
    print(f"  Original prediction: {CLASS_NAMES[orig_preds[0]]} (confidence: {orig_confs[0]:.3f})")
    print(f"  Adversarial prediction: {CLASS_NAMES[adv_preds[0]]} (confidence: {adv_confs[0]:.3f})")
    print(f"  Attack successful: {orig_preds[0] != adv_preds[0]}")
    return output_filename


def test_model(model: nn.Module, pathname: str | Path, run_timestamp: str) -> None:
    print(f"Testing model using images from {pathname}...")
    model.eval()
    images = list(Path(pathname).glob("*/*"))
    if not images:
        raise ValueError(f"No test images found under {pathname}/*/*")

    img_path = random.choice(images)
    image, input_tensor = load_image_tensor(img_path)

    with torch.inference_mode():
        logits = get_logits(model(input_tensor))
        probs = torch.softmax(logits, dim=1)
        pred = probs.argmax(dim=1).item()
        confidence = probs[0, pred].item()

    true_label = img_path.parent.name
    output_path = SCRIPT_DIR / f"{run_timestamp}-output.png"

    plt.imshow(image)
    plt.title(f"True: {true_label}, Pred: {CLASS_NAMES[pred]} ({confidence:.3f})")
    plt.axis("off")
    plt.savefig(output_path)
    plt.close()
    print(f"Plot saved to {output_path}")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Train ad safety classifier with optional adversarial training."
    )
    parser.add_argument("--model-path", type=str, default=None, help="Load a pre-trained model")
    parser.add_argument("--adversarial", action="store_true", help="Enable adversarial training")
    parser.add_argument("--adv-epsilon", type=float, default=0.15, help="Adversarial perturbation magnitude")
    parser.add_argument("--adv-steps", type=int, default=20, help="Attack iterations for adversarial batches")
    parser.add_argument("--epochs", type=int, default=DEFAULT_EPOCHS, help="Number of training epochs")
    parser.add_argument("--batch-size", type=int, default=DEFAULT_BATCH_SIZE, help="Training batch size")
    parser.add_argument("--seed", type=int, default=None, help="Random seed. Defaults to a random value per run")
    return parser.parse_args()


def build_training_config(args: argparse.Namespace) -> TrainingConfig:
    return TrainingConfig(
        epochs=args.epochs,
        batch_size=args.batch_size,
        adversarial=args.adversarial,
        adv_epsilon=args.adv_epsilon,
        adv_steps=args.adv_steps,
    )


def load_datasets() -> tuple[datasets.ImageFolder, datasets.ImageFolder, datasets.ImageFolder]:
    print(f"Loading datasets from {DATA_DIR}...")
    train_dataset = datasets.ImageFolder(DATA_DIR / "train", transform=IMAGE_TRANSFORM)
    val_dataset = datasets.ImageFolder(DATA_DIR / "val", transform=IMAGE_TRANSFORM)
    test_dataset = datasets.ImageFolder(DATA_DIR / "test", transform=IMAGE_TRANSFORM)
    return train_dataset, val_dataset, test_dataset


def resolve_model_path(model_path_arg: str | None) -> Path | None:
    if model_path_arg is None:
        return None

    model_path = Path(model_path_arg)
    if not model_path.exists():
        raise FileNotFoundError(f"Specified model path does not exist: {model_path}")
    return model_path


def main() -> None:
    args = parse_args()
    config = build_training_config(args)
    run_timestamp = datetime.now().strftime("%Y-%m-%d-%H-%M-%S")
    seed = args.seed if args.seed is not None else make_seed()
    set_seed(seed)

    model_path = resolve_model_path(args.model_path)
    print(f"Using device: {DEVICE}")
    print(f"Using seed: {seed}")

    train_dataset, val_dataset, test_dataset = load_datasets()
    train_loader = make_data_loader(train_dataset, batch_size=config.batch_size, shuffle=True)
    val_loader = make_data_loader(val_dataset, batch_size=config.batch_size, shuffle=False)
    _ = test_dataset

    if model_path is not None:
        model = load_model(model_path)
        print(f"Loaded model from: {model_path}")
        print("Skipping training. Running test and adversarial demo.")
    else:
        model = make_model()
        criterion = nn.CrossEntropyLoss()
        optimizer = optim.Adam(model.parameters(), lr=config.learning_rate)
        train_model(model, train_loader, val_loader, optimizer, criterion, config)
        model_path = SCRIPT_DIR / f"{run_timestamp}-model.pth"
        save_model(model, model_path)

    test_model(model, DATA_DIR / "test", run_timestamp)

    print("\nGenerating adversarial attack example...")
    test_images = list((DATA_DIR / "test").glob("*/*"))
    if test_images:
        random_test_image = random.choice(test_images)
        generate_adversarial_example(
            model=model,
            image_path=random_test_image,
            run_timestamp=run_timestamp,
            epsilon=config.adv_epsilon,
            num_steps=max(config.adv_steps, 1),
        )


if __name__ == "__main__":
    main()
